# Set by render.yaml automatically — do not add to Render env-var groups
ENV=staging   # or: production

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Phone numbers in E.164 format (+12025551234)
# For staging, point TO_PHONE_NUMBER at your own number for safe testing.
# For production, point it at the intended recipient.
TWILIO_FROM_NUMBER=+15005550006
TO_PHONE_NUMBER=+12025551234
